
{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ProjexNexa",
  "version": "0.1.7",
  "identifier": "com.CanadianGamer.ProjexNexa",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "enableGTKAppId": false,
    "macOSPrivateApi": false,
    "windows": [
      {
        "title": "Projex-Nexa",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/PN.png",
      "icons/PN.icns",
      "icons/PN.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false,
        "files": {}
      },
      "deb": {
        "files": {}
      },
      "rpm": {
        "epoch": 0,
        "files": {},
        "release": "1"
      }
    },
    "macOS": {
    "dmg": {
      "background": "./images/bg.png",
      "appPosition": {
        "x": 180,
        "y": 170
      },
      "applicationFolderPosition": {
        "x": 480,
        "y": 170
      },
      "windowSize": {
        "height": 600,
        "width": 860
      }
    },
    "files": {},
    "hardenedRuntime": true,
    "minimumSystemVersion": "10.13"
  },
  "windows": {
				"certificateThumbprint": null,
				"digestAlgorithm": "sha256",
				"timestampUrl": "",
        "wix":{
          "template": "./wix/installer.wxs"
        }
			}

  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGNkQ2OTg3NDk5MjMxNTUKUldSVk1aSkpoMmx0Nzk2TCtrYWNaZys0blBYbkFsTjdYQzNkbWVpb1EyZHdEZTZCbDBrZTFydHMK",
      "endpoints": [
        "https://raw.githubusercontent.com/EasyCanadianGamer/ProjexNexa/main/latest.json"
      ]
    }
  }
}
